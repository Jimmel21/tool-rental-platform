# Database (PostgreSQL)
# Local example: postgresql://postgres:YOUR_PASSWORD@localhost:5432/tool_rental?schema=public
# Or no password: postgresql://postgres@localhost:5432/tool_rental?schema=public
# Cloud: use the connection string from Neon, Supabase, Railway, etc.
DATABASE_URL="postgresql://jimmelgreer@localhost:5432/tool_rental?schema=public"

# NextAuth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-at-least-32-chars"
# Full URL of your app (e.g. http://localhost:3000 in development)
NEXTAUTH_URL="http://localhost:3000"

# Optional: OAuth providers (add when configuring)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
