# Database (PostgreSQL)
# Local example: postgresql://postgres:YOUR_PASSWORD@localhost:5432/tool_rental?schema=public
# Or no password: postgresql://postgres@localhost:5432/tool_rental?schema=public
# Cloud: use the connection string from Neon, Supabase, Railway, etc.
DATABASE_URL="postgresql://jimmelgreer@localhost:5432/tool_rental?schema=public"

# NextAuth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-at-least-32-chars"
# Full URL of your app (e.g. http://localhost:3000 in development)
NEXTAUTH_URL="http://localhost:3000"

# WhatsApp (T&T: +1 868 XXX XXXX — use digits only, e.g. 18681234567)
NEXT_PUBLIC_WHATSAPP_NUMBER="18683435678"

# Email (Brevo / Sendinblue)
BREVO_API_KEY="your-brevo-api-key"  # Get from https://app.brevo.com/settings/keys/api
EMAIL_FROM_ADDRESS="noreply@toolrental.tt"
EMAIL_FROM_NAME="Tool Rental TT"

# WiPay (primary payment gateway — https://wipay.co.tt)
WIPAY_ACCOUNT_NUMBER="your-wipay-account-number"
WIPAY_API_KEY="your-wipay-api-key"
# Production: https://checkout.wipay.co.tt  |  Sandbox: https://sandbox.wipay.co.tt
WIPAY_BASE_URL="https://checkout.wipay.co.tt"

# Optional: OAuth providers (add when configuring)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
